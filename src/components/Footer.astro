---
const today = new Date();

// Grab the current URL path
const currentPath = Astro.url.pathname;

// Check if the path is the about page (handles both with and without a trailing slash)
const isAboutPage = currentPath === '/about' || currentPath === '/about/';
---

<footer>
  {isAboutPage && (
    <div class="contact-footer">
      <strong>Contact:</strong> <a href="mailto:ridge.valley5992@eagereverest.com">ridge.valley5992@eagereverest.com</a>
    </div>
  )}

  <p>&copy; {today.getFullYear()} LiquidFlame. All rights reserved.</p>
  <p class="amazon-disclaimer">As an Amazon Associate I earn from qualifying purchases.</p>
</footer>

<style>
  footer {
    padding: 2em 1em 6em 1em;
    background: transparent;
    color: rgb(var(--gray));
    text-align: center;
  }
  .disclosure {
    font-size: 0.8rem;
    margin-top: 1rem;
    font-style: italic;
    opacity: 0.8;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    text-decoration: none;
    color: rgb(var(--gray));
  }
  .social-links a:hover {
    color: rgb(var(--gray-dark));
  }
  .contact-footer {
    text-align: center;
    margin-bottom: 1.5rem; /* Adds space between the email and the copyright */
    font-size: 0.95em; /* Optional: makes it slightly smaller to match the footer vibe */
  }
</style>
