---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // 1. Fetch all posts using your Content Collections setup
  const allPosts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  // 2. Extract every unique tag from the frontmatter
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))];

  // 3. Generate a page for each tag
  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags?.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()); // Sort by newest

    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

// Ensure base URL is correct for images/links just like index.astro
const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`#${tag} | LiquidFlame's Blog`} description={`Posts about ${tag}`} />
    <style>
      /* Borrowed directly from your index.astro to ensure perfect matching */
      ul {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li a {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        text-decoration: none;
        transition: 0.2s ease;
      }
      ul li img {
        width: 240px;
        height: 140px;
        object-fit: cover;
        border-radius: 8px;
      }
      .post-content {
        flex: 1;
      }
      .title {
        margin: 0;
        color: rgb(var(--black));
        font-size: 1.4rem;
        font-weight: bold;
        line-height: 1.2;
      }
      .date {
        margin: 0.25rem 0 0;
        color: rgb(var(--gray));
        font-size: 0.9rem;
      }
      .description {
        margin: 0.5rem 0 0;
        color: rgb(var(--gray-dark));
        font-size: 1rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
      }
      ul li a:hover .title {
        color: var(--accent);
      }
      ul li a:hover img {
        box-shadow: var(--box-shadow);
      }
      
      .tag-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid rgb(var(--gray-light));
      }

      @media (max-width: 720px) {
        ul li a {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;
        }
        ul li img {
          width: 100%;
          height: 180px;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <div class="tag-header">
          <a href="/" style="text-decoration: none; color: rgb(var(--gray));">&larr; Back to all posts</a>
          <h1 style="margin-top: 1rem;">Posts tagged: <span style="color: var(--accent);">#{tag}</span></h1>
        </div>

        <ul>
          {
            posts.map((post) => (
              <li>
                <a href={`${BASE}blog/${post.id}/`}>
                  <img 
                    src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src || '/placeholder.jpg'} 
                    alt="" 
                  />
                  <div class="post-content">
                    <h4 class="title">{post.data.title}</h4>
                    {post.data.description && <p class="description">{post.data.description}</p>}
                    <p class="date">
                      <FormattedDate date={post.data.pubDate} />
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>